{
  "bash": {
    "command": "bash-language-server",
    "args": ["start"],
    "extensionToLanguage": {
      ".sh": "bash",
      ".bash": "bash",
      ".bashrc": "bash",
      ".bash_profile": "bash",
      ".bash_login": "bash",
      ".bash_logout": "bash",
      ".profile": "bash",
      ".zsh": "bash",
      ".zshrc": "bash"
    },
    "initializationOptions": {
      "shellcheckPath": "/usr/bin/shellcheck",
      "highlightParsingErrors": true
    },
    "startupTimeout": 5000,
    "shutdownTimeout": 2000,
    "restartOnCrash": true,
    "maxRestarts": 3
  }
}
