{
  "bash": {
    "command": "bash-language-server",
    "args": ["start"],
    "extensionToLanguage": {
      ".sh": "bash",
      ".bash": "bash"
    },
    "env": {
      "GLOB_PATTERN": "**/*@(.sh|.bash)",
      "SHELLCHECK_ARGUMENTS": "--rcfile ${CLAUDE_PLUGIN_ROOT}/.shellcheckrc",
      "SHELLCHECK_PATH": "shellcheck",
      "SHFMT_IGNORE_EDITORCONFIG": "false",
      "SHFMT_LANGUAGE_DIALECT": "auto",
      "SHFMT_PATH": "shfmt"
    }
  }
}
